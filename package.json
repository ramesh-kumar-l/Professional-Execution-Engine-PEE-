{
  "name": "professional-execution-engine",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate -w @pee/database"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "allowScripts": {
    "@nestjs/core@10.4.22": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "argon2@0.41.1": true,
    "esbuild@0.21.5": true,
    "prisma@5.22.0": true,
    "unrs-resolver@1.12.2": true
  }
}
