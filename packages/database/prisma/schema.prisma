generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum ExecutionEventType {
  TASK_STARTED
  TASK_STATUS_CHANGED
  TASK_COMPLETED
  TASK_ARCHIVED
  GOAL_STATUS_CHANGED
}

enum AIRecommendationType {
  GOAL_TASK_BREAKDOWN
}

enum AIRecommendationStatus {
  PENDING
  ACCEPTED
  DISMISSED
  FAILED
}

// Client-generated UUID primary keys + updatedAt/version columns on every
// syncable table, per adr/0003 (keeps offline sync possible later without
// a schema rewrite).
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  version       Int            @default(1)
  refreshTokens RefreshToken[]
  auditLogs     AuthAuditLog[]
  projects      Project[]
  goals         Goal[]
  tasks         Task[]
  executionSessions TaskExecutionSession[]
  executionEvents   ExecutionEvent[]
  aiRecommendations AIRecommendation[]

  @@map("users")
}

model RefreshToken {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String        @unique
  issuedAt          DateTime      @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?       @unique
  replacedByToken   RefreshToken? @relation("TokenRotation", fields: [replacedByTokenId], references: [id])
  previousToken     RefreshToken? @relation("TokenRotation")
  updatedAt         DateTime      @updatedAt
  version           Int           @default(1)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuthAuditLog {
  id        String        @id @default(uuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType AuthEventType
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  version   Int           @default(1)

  @@index([userId])
  @@map("auth_audit_logs")
}

model Project {
  id          String        @id @default(uuid())
  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  version     Int           @default(1)
  goals       Goal[]

  @@index([ownerId])
  @@index([ownerId, updatedAt])
  @@map("projects")
}

model Goal {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      GoalStatus @default(NOT_STARTED)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  version     Int        @default(1)
  tasks       Task[]
  executionEvents ExecutionEvent[]
  aiRecommendations AIRecommendation[]

  @@index([projectId])
  @@index([ownerId])
  @@index([ownerId, updatedAt])
  @@map("goals")
}

model Task {
  id          String     @id @default(uuid())
  goalId      String
  goal        Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  order       Int        @default(0)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  version     Int        @default(1)
  executionSessions TaskExecutionSession[]
  executionEvents   ExecutionEvent[]

  @@index([goalId])
  @@index([ownerId])
  @@index([ownerId, updatedAt])
  @@map("tasks")
}

model TaskExecutionSession {
  id              String    @id @default(uuid())
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  version         Int       @default(1)

  @@index([taskId])
  @@index([ownerId])
  @@map("task_execution_sessions")
}

// Append-only log — never mutated after insert, so unlike every other
// table here it intentionally has no updatedAt/version (adr/0003's
// sync-merge columns exist for mutable rows; a log entry has nothing
// to merge).
model ExecutionEvent {
  id         String             @id @default(uuid())
  ownerId    String
  owner      User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  goalId     String?
  goal       Goal?              @relation(fields: [goalId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  eventType  ExecutionEventType
  fromStatus String?
  toStatus   String?
  createdAt  DateTime           @default(now())

  @@index([ownerId])
  @@index([goalId])
  @@index([taskId])
  @@index([ownerId, createdAt])
  @@map("execution_events")
}

model AIRecommendation {
  id          String                 @id @default(uuid())
  ownerId     String
  owner       User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  goalId      String
  goal        Goal                   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  type        AIRecommendationType
  status      AIRecommendationStatus @default(PENDING)
  context     Json
  suggestions Json
  provider    String
  model       String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  version     Int                    @default(1)
  respondedAt DateTime?

  @@index([ownerId])
  @@index([goalId])
  @@map("ai_recommendations")
}
