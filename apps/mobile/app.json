    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.pee.mobile",
      "supportsTablet": false
    },
    "android": {
      "package": "com.pee.mobile"
    },
    "plugins": ["expo-secure-store", "expo-sqlite"]
  }
}
