# Copy to .env and fill in real values. Never commit .env.

# --- services/api & packages/database ---
DATABASE_URL="postgresql://pee:pee@localhost:5432/pee_dev?schema=public"
PORT=3001

# JWT (services/auth) — use long random strings, different per environment
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_TTL="7d"

# --- apps/web (Next.js / Auth.js) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"
INTERNAL_API_URL="http://localhost:3001"
