# Copy to .env and fill in real values. Never commit .env.

# --- services/api & packages/database ---
DATABASE_URL="postgresql://pee:pee@localhost:5432/pee_dev?schema=public"
PORT=3001

# JWT (services/auth) — use long random strings, different per environment
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_TTL="7d"

# --- services/ai ---
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY="change-me-anthropic-key"
ANTHROPIC_MODEL="claude-sonnet-5"
OPENAI_API_KEY="change-me-openai-key"
OPENAI_MODEL="gpt-4o-mini"

# --- apps/web (Next.js / Auth.js) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"
INTERNAL_API_URL="http://localhost:3001"

# --- SSO (Phase 10, additive — leave unset to keep SSO disabled) ---
# Shared secret for apps/web -> services/auth server-to-server SSO provisioning
# calls (SsoProvisionGuard). Required for BOTH OIDC and SAML provisioning to work.
SSO_INTERNAL_SECRET="change-me-sso-internal-secret"

# OIDC — Auth.js's native `type: 'oidc'` provider runs the whole exchange; set all
# three to enable the "Enterprise SSO" login button.
SSO_OIDC_ISSUER_URL=""
SSO_OIDC_CLIENT_ID=""
SSO_OIDC_CLIENT_SECRET=""

# SAML — no native Auth.js provider type, so services/auth runs a real SP behind an
# OAuth2-shaped bridge. Set all of SSO_SAML_ENTRY_POINT/ISSUER/IDP_CERT/CALLBACK_URL
# to enable the "Enterprise SSO (SAML)" login button.
SSO_SAML_ENTRY_POINT=""
SSO_SAML_ISSUER=""
SSO_SAML_IDP_CERT=""
SSO_SAML_CALLBACK_URL=""
SSO_SAML_CLIENT_ID="pee-web"
# Signs the SAML bridge's short-lived tokens. Its own secret, never a fallback to
# JWT_ACCESS_SECRET — required for the SAML routes to serve anything but 503.
SSO_SAML_BRIDGE_SECRET="change-me-saml-bridge-secret"
# Comma-separated origins the SAML ACS handler is allowed to redirect back to.
SSO_SAML_ALLOWED_REDIRECT_ORIGIN="http://localhost:3000"
