generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

// Client-generated UUID primary keys + updatedAt/version columns on every
// syncable table, per adr/0003 (keeps offline sync possible later without
// a schema rewrite).
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  version       Int            @default(1)
  refreshTokens RefreshToken[]
  auditLogs     AuthAuditLog[]
  projects      Project[]
  goals         Goal[]
  tasks         Task[]

  @@map("users")
}

model RefreshToken {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String        @unique
  issuedAt          DateTime      @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?       @unique
  replacedByToken   RefreshToken? @relation("TokenRotation", fields: [replacedByTokenId], references: [id])
  previousToken     RefreshToken? @relation("TokenRotation")
  updatedAt         DateTime      @updatedAt
  version           Int           @default(1)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuthAuditLog {
  id        String        @id @default(uuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType AuthEventType
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  version   Int           @default(1)

  @@index([userId])
  @@map("auth_audit_logs")
}

model Project {
  id          String        @id @default(uuid())
  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  version     Int           @default(1)
  goals       Goal[]

  @@index([ownerId])
  @@map("projects")
}

model Goal {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      GoalStatus @default(NOT_STARTED)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  version     Int        @default(1)
  tasks       Task[]

  @@index([projectId])
  @@index([ownerId])
  @@map("goals")
}

model Task {
  id          String     @id @default(uuid())
  goalId      String
  goal        Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  order       Int        @default(0)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  version     Int        @default(1)

  @@index([goalId])
  @@index([ownerId])
  @@map("tasks")
}
